# Copy to .env at the repository root, then run crawlers from the repo root:
#   bun run crawl:links
#   bun run crawl:questions
BASE_URL=full_url_to_your_application
# Optional crawl settings (defaults: START_PAGE=1, END_PAGE=600, MAX_LINKS=113)
# START_PAGE=1
# END_PAGE=600
# MAX_LINKS=113
# Optional override for question data directory (default: <repo-root>/data)
# DATA_DIR=data
